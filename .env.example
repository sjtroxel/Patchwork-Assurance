# Local dev: the Streamlit UI calls the FastAPI service at this base URL.
API_BASE_URL=http://localhost:8000

# ---- LLM provider ----
# Default is a free, offline stub (LLM_PROVIDER=stub): retrieval and citations are real, but the
# generated prose is a "(stub)" placeholder. For real generation, copy this file to .env (gitignored)
# and set ONE of the provider blocks below. Never commit a real key.
LLM_PROVIDER=stub   # stub | anthropic | openrouter

# Two-model split (Phase 5): chat = fast/cheap, memo = stronger reasoning; judge = eval-only tier.
# Defaults below are the Anthropic ids; override per provider.

# -- Option A: Anthropic (console.anthropic.com, pay-per-token) --
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...            # from console.anthropic.com — secret, never commit
# CHAT_MODEL=claude-haiku-4-5             # $1 / $5 per 1M in/out
# MEMO_MODEL=claude-sonnet-5             # $2 / $10 intro thru 2026-08-31, then $3 / $15
# JUDGE_MODEL=claude-opus-4-8             # judged eval tier only

# -- Option B: OpenRouter (one key fronts ~315 models incl. FREE ones; OpenAI-compatible) --
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...            # from openrouter.ai/keys — secret, never commit
# Free-tier picks (verify current ids at https://openrouter.ai/collections/free-models — the lineup
# churns; pick models that support BOTH tool calling and structured output). Keep JUDGE != MEMO so the
# judged eval tier doesn't grade its own family.
# CHAT_MODEL=openai/gpt-oss-20b:free      # Haiku-like stand-in: fast, lighter
# MEMO_MODEL=openai/gpt-oss-120b:free     # Sonnet-like stand-in: stronger; needs JSON/structured output
# JUDGE_MODEL=google/gemma-4-31b-it:free  # different family from MEMO
