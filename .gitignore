# OS / editor junk
.DS_Store
Thumbs.db
*.swp
.vscode/

# Convention: anything kept local-only goes in private/
private/

# Secrets — NEVER commit API keys (Anthropic/OpenAI/etc.)
.env
.env.*
# keep the key-less template tracked (it documents the config)
!.env.example
*.key

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Local vector store (Chroma persistence)
.chroma/
chroma/
*.sqlite3

# Local MCP client config (created by `claude mcp add`) — holds a machine-specific
# absolute interpreter path. The README documents the portable config to use instead.
.mcp.json

# Eval scorecards (JSON run output) — reproducible by re-running `make eval`
eval/results/

# Raw statute source PDFs — provenance only, reproducible from source_url in metadata.
# The cleaned corpus/*.md (and *.meta.yaml) ARE committed; the heavy binaries are not.
# The folder's README.md IS committed; only the .pdf scans are ignored.
corpus/ocr-source-pdfs/*.pdf

# Downloaded CI run logs (e.g. logs_<run-id>.zip from the GitHub Actions UI)
logs_*.zip
*.zip

# Phase 9 monitoring agent runtime artifacts
# .agent_hashes.json = last-seen content hashes (not repo state, re-built by poll)
# corpus/_staging/ = draft staging area, merged into corpus/ via PR then cleared
.agent_hashes.json
corpus/_staging/

# Phase 13 national radar runtime artifacts
# (comments must be on their own line — an inline '#' is part of the pattern, not a comment)
# .radar_store.json = per-bill radar state (change_hash/issue_number), persisted via Actions cache
# radar_summary.json = detection summary emitted per run, read by the workflow, not repo state
.radar_store.json
radar_summary.json

# Phase 14 write-up carousel: rendered PNGs (out/) ARE tracked so the slides are viewable on GitHub.
# Only the throwaway intermediate HTML is ignored; rebuild all with
# `python3 build_slides.py && bash render.sh`.
writeups/phase-14-grounding/carousel/_slide_*.html
